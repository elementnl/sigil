{
  "git": {
    "commitMessage": "Release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": ["npm run typecheck", "npm run lint", "npm test"]
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "../CHANGELOG.md"
    }
  }
}
